# Backend API URL (FastAPI on Railway/Render/localhost)
VITE_API_URL=http://localhost:8000

# Google Maps JavaScript API Key
# Same project as the backend geocoding key — enable "Maps JavaScript API" in GCP Console
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Shared secret sent as the X-API-Key header on every backend request.
# Must match the backend's API_KEY env var.
VITE_API_KEY=your_backend_api_key_here
