OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
RAKUTEN_APP_ID=your_rakuten_app_id_here
RAKUTEN_ACCESS_KEY=your_rakuten_access_key_here
RAKUTEN_HOTEL_URL=rakuten_base_api_url
# Shared secret the frontend must send as the X-API-Key header on /chat and /hotels.
# Must match the frontend's VITE_API_KEY. Generate one with: openssl rand -hex 32
API_KEY=your_backend_api_key_here

# --- LangSmith step-level tracing (optional, OFF by default) ---
# Captures per-ReAct-step latency, tool calls, and token usage for the GPT-4o
# agent so we can measure a baseline before the slot-filling/workflow migration.
# Leave these unset/false and the app runs exactly as before (zero tracing,
# no LangSmith calls). To turn tracing ON, set LANGSMITH_TRACING=true and provide
# an API key from https://smith.langchain.com (Settings -> API Keys).
# Modern LANGSMITH_* names are shown; the legacy LANGCHAIN_TRACING_V2 /
# LANGCHAIN_API_KEY / LANGCHAIN_PROJECT / LANGCHAIN_ENDPOINT aliases also work.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=onsen-guide-bot
# US SaaS endpoint by default; use https://eu.api.smith.langchain.com for the EU region.
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
